# ── הגדרות אדמין ──
ADMIN_PASSWORD=chavaya2025
ADMIN_SECRET=chavaya-super-secret-key-2025-minimum-32-chars!!

# ── מסד נתונים Supabase (הזמנות, פניות, פעילויות) ──
# Supabase → Project Settings → Data API / API Keys
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── התראות אימייל (הזמנות + פניות) דרך Resend ──
# 1. הרשם ב-resend.com (חינם) עם המייל שאליו תרצה לקבל את הלידים
# 2. API Keys → Create → העתק את המפתח
RESEND_API_KEY=
NOTIFY_EMAIL_TO=office.chavayasl@gmail.com
# אופציונלי — דורש אימות דומיין ב-Resend. בלי זה משאירים ריק:
# NOTIFY_EMAIL_FROM=חוויה סביב השנה <noreply@yourdomain.co.il>
